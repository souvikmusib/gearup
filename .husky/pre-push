# Block a push unless the full local gate passes. A complete business depends
# on this software — no red push reaches main.
echo "▶ pre-push gate: unit → integration → typecheck → lint"
pnpm --filter @gearup/web test || { echo "✖ unit tests failed — push blocked"; exit 1; }
pnpm --filter @gearup/web test:int || { echo "✖ integration tests failed — push blocked"; exit 1; }
pnpm --filter @gearup/web exec tsc --noEmit || { echo "✖ typecheck failed — push blocked"; exit 1; }
pnpm lint || { echo "✖ lint failed — push blocked"; exit 1; }
echo "✔ all gates green — pushing"
