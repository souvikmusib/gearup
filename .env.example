# ──────────────────────────────────────────────
# GearUp Servicing – Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# ── Supabase ─────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<your-anon-key>
NEXT_PUBLIC_SUPABASE_PROJECT_ID=<your-project-id>

# ── Supabase Postgres (via Prisma) ──────────
DATABASE_URL=postgresql://postgres.<project-id>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DIRECT_URL=postgresql://postgres.<project-id>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# ── Auth ─────────────────────────────────────
JWT_SECRET=change-me-in-production-min-16-chars

# ── App ──────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_NAME=GearUp Servicing
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Sentry (optional) ───────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
