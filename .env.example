# ──────────────────────────────────────────────
# GearUp Servicing – Environment Variables
# Copy to .env and fill in real values
# ──────────────────────────────────────────────

# ── Frontend (apps/web) ──────────────────────
NEXT_PUBLIC_APP_NAME=GearUp Servicing
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_THEME_DEFAULT=light

# ── Backend (apps/api) ──────────────────────
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:password@localhost:5432/gearup
CORS_ALLOWED_ORIGINS=http://localhost:3000
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production

# ── Supabase ─────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET_SERVICE_REQUESTS=service-requests
SUPABASE_STORAGE_BUCKET_JOB_CARDS=job-cards
SUPABASE_STORAGE_BUCKET_EXPENSES=expenses
SUPABASE_STORAGE_BUCKET_INVOICES=invoices

# ── Sentry (Backend) ────────────────────────
SENTRY_DSN=

# ── WhatsApp ─────────────────────────────────
WHATSAPP_PROVIDER=
WHATSAPP_API_KEY=
WHATSAPP_API_URL=

# ── Email ────────────────────────────────────
EMAIL_PROVIDER=
EMAIL_API_KEY=
EMAIL_FROM_ADDRESS=noreply@gearupservicing.com

# ── Cron / Jobs ──────────────────────────────
CRON_ENABLED=true

# ── Misc ─────────────────────────────────────
OWNER_SUMMARY_EMAIL=
APP_BASE_URL=http://localhost:3000
PUBLIC_TRACK_URL_BASE=http://localhost:3000/track
